# ----------------------------------------------------
# Python Ignore List (Standard Template)
# ----------------------------------------------------

# 1. Compiled Code (Bytecode)
# Ignore all __pycache__ directories at any level (current, sub, sub-sub, etc.)
# The double asterisk (**) matches any directory depth.
**/__pycache__/

# Compiled Python files
*.pyc
*.pyd
*.pyo

# 2. Virtual Environments
# ------------------------------------
# Ignore common virtual environment directories
venv/
env/
.venv/
.env/

# 3. Packaging and Distribution Files
# ------------------------------------
# Ignore files generated during build and installation processes
build/
dist/
*.egg-info/
.eggs/

# 4. Testing and Coverage Reports
# ------------------------------------
.pytest_cache/
.coverage
htmlcov/
nosetests.xml

# 5. IDE and Editor Specific Files
# ------------------------------------
# PyCharm
.idea/

# VS Code
.vscode/

# Vim/Emacs swap and backup files
*.swp
*~

# 6. Operating System Files
# ------------------------------------
# macOS temporary files
.DS_Store 

# Windows thumbnail cache
Thumbs.db 

# 7. Jupyter Notebook and IPython Checkpoints
# ------------------------------------
.ipynb_checkpoints 

# 8. Logs and Local Databases
# ------------------------------------
*.log
*.sqlite3

cifs_v1_orig.tar.gz
.env
apikey
.vscode
checkpoints/
checkpoints_merged/**/*
!checkpoints_merged/**/
!checkpoints_merged/**/*.parquet
outputs
swanlog
temp
generation_results.csv
flash_attn*
logs/
*.out
.cache/
.claude/
*.html
AGENTS.md
pyrightconfig.json
paper/*
.codex